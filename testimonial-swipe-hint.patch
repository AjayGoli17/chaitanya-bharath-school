+
+/* Swipe hint: quiet label + nudging arrow, shown briefly the first
+   time the section scrolls into view on mobile */
+.test-swipe-hint {
+    display: none;
+    align-items: center;
+    justify-content: center;
+    gap: 6px;
+    margin-top: 10px;
+    font-size: 12px;
+    color: var(--text-muted);
+    opacity: 0;
+    transition: opacity 0.4s ease;
+}
+@media (max-width: 1024px) {
+    .test-swipe-hint { display: flex; }
+}
+.test-swipe-hint.show { opacity: 1; }
+.test-swipe-hint i { font-size: 11px; }
+.test-swipe-hint.nudge i.fa-chevron-right {
+    animation: testHintNudge 1.1s ease-in-out 2;
+}
+@keyframes testHintNudge {
+    0%, 100% { transform: translateX(0); }
+    50% { transform: translateX(4px); }
+}
