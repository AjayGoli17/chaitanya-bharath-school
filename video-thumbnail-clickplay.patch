@@ -325,16 +325,27 @@ function toggleVideo(wrapper) {
     galItems.forEach(item => observer.observe(item));
 })();
 /* =========================================================
-   Force-start the silent event-card video previews.
-   Some browsers (notably Safari) don't reliably honor the
-   HTML autoplay attribute alone — explicitly play() each one.
+   Event-card video previews.
+   Force the browser to decode & paint the video's own real
+   first frame as soon as data is available, so the card shows
+   actual video content instead of a black box — before the
+   user ever clicks play. Playback itself only starts on click,
+   via toggleVideo() above.
    ========================================================= */
 document.querySelectorAll('.event-vid video').forEach(video => {
     video.muted = true;
-    const startPreview = () => video.play().catch(() => {});
-    if (video.readyState >= 2) {
-        startPreview();
+
+    const paintFirstFrame = () => {
+        try {
+            if (video.currentTime === 0) {
+                video.currentTime = 0.1;
+            }
+        } catch (e) { /* ignore seek errors */ }
+    };
+
+    if (video.readyState >= 1) {
+        paintFirstFrame();
     } else {
-        video.addEventListener('loadeddata', startPreview, { once: true });
+        video.addEventListener('loadedmetadata', paintFirstFrame, { once: true });
     }
 });
